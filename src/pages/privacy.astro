---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Privacy Policy — Homeputers" description="Homeputers LLC privacy policy.">
  <Header />

  <main class="section">
    <div class="container">
      <div class="page-header">
        <p class="section-label">Legal</p>
        <h1 class="page-title">Privacy Policy</h1>
        <p class="page-date">Last updated: January 2025</p>
      </div>

      <article class="prose">
        <h2>Information we collect</h2>
        <p>
          We collect only the information necessary to communicate with prospective and current clients —
          such as your name, email address, and phone number. This information is provided voluntarily when
          you contact us.
        </p>

        <h2>How we use your information</h2>
        <p>
          We use your contact information solely to respond to your inquiries and manage our consulting
          engagements. We do not use your data for marketing to third parties or automated profiling.
        </p>

        <h2>Data sharing</h2>
        <p>
          We do not sell, rent, or trade your personal data to any third party. We may share information
          with service providers who assist our operations (such as email hosting) under strict
          confidentiality agreements.
        </p>

        <h2>Data retention</h2>
        <p>
          We retain your information for as long as necessary to fulfill the purpose for which it was
          collected, or as required by applicable law.
        </p>

        <h2>Your rights</h2>
        <p>
          You may request access to, correction of, or deletion of your personal information at any time
          by contacting us at <a href="mailto:info@homeputers.com">info@homeputers.com</a>.
        </p>

        <h2>Contact</h2>
        <p>
          For privacy questions or requests, please email <a href="mailto:info@homeputers.com">info@homeputers.com</a>.
        </p>
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 56px;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #f1f5f9;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    margin-top: 12px;
  }

  .page-date {
    font-size: 0.875rem;
    color: var(--text-faint);
  }

  .prose {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .prose h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 10px;
  }

  .prose p {
    color: var(--text-muted);
    line-height: 1.8;
  }

  .prose a {
    color: var(--accent);
  }
</style>
